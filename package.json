{
  "name": "pi-memora",
  "version": "1.0.1",
  "description": "Memora-backed persistent memory extension for the Pi coding agent.",
  "main": "extensions/memora.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bridge:doctor": "uv run --project . python bridge/pi_memora_bridge.py doctor '{}'",
    "bridge:smoke": "uv run --project . python -m py_compile bridge/pi_memora_bridge.py && (uv run --project . python bridge/pi_memora_bridge.py doctor '{}' || test $? -eq 2)",
    "test": "npm run typecheck && npm run bridge:smoke"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "memory",
    "memora"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "extensions/*.ts",
    "bridge/*.py",
    "pyproject.toml",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "typebox": "^1.3.2"
  }
}
